{
  "name": "veles",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "check": "pnpm fmt:check && pnpm lint:css && pnpm typecheck && pnpm test",
    "check:fix": "pnpm fmt && pnpm lint:css:fix && pnpm typecheck && pnpm test run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "drizzle-kit migrate --config=drizzle-prod.config.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:studio:prod": "drizzle-kit studio --config=drizzle-prod.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@base-ui/react": "1.5.0",
    "@better-auth/drizzle-adapter": "1.6.11",
    "@tanstack/arktype-adapter": "1.167.0",
    "@tanstack/react-pacer": "0.22.1",
    "@tanstack/react-query": "5.100.12",
    "@tanstack/react-query-devtools": "5.100.12",
    "@tanstack/react-router": "1.170.7",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.25",
    "arktype": "2.2.0",
    "better-auth": "1.6.11",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.17.0",
    "pg": "8.16.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "4.0.0",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "nitro": "3.0.260522-beta",
    "oxfmt": "0.51.0",
    "postcss": "8.5.15",
    "postcss-custom-media": "12.0.1",
    "stylelint": "16.26.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=26.2.0"
  },
  "packageManager": "pnpm@11.5.0"
}
