# Runtime environment variables

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veles_dev
PROD_DATABASE_URL=postgresql://user:password@prod-host:5432/veles_prod

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
APP_URL=http://localhost:3000
# Comma-separated, exact Google account addresses. Empty means no new accounts.
AUTH_ALLOWED_EMAILS=krzysztofwidacki@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Build-time environment variables
VITE_APP_NAME=Veles
VITE_CF_CDN_URL=https://cdn.example.com
