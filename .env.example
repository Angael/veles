# Runtime environment variables

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veles_dev
# Used by drizzle-prod.config.ts for manual prod migrations
PROD_DATABASE_URL=postgresql://user:password@prod-host:5432/veles_prod

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-char-secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Build-time environment variables

VITE_APP_NAME=Veles
VITE_APP_URL=http://localhost:3000
VITE_CF_CDN_URL=https://cdn.example.com
